#include <iostream>
using namespace std;
void triplicar(int &n) {
 n = n * 3;
}
int main() {
 int valor;

 cout << "Digite um número para triplicar: " <<endl;
 cin >> valor;

 triplicar(valor);
 cout << "Resultado triplicado é: " << valor << endl;

 return 0;
}

