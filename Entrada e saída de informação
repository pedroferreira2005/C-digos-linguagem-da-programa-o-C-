#include <iostream>
#include <string>
using namespace std;

int main () {
   string nome;
   int quantidade;
   float preço;
  
   cout << "Digite o nome do produto : " << endl;
   cin >> nome;
  
   cout << "Digite a quantidade em estoque: " << endl;
   cin >> quantidade;
  
   cout << "Digite o preço unitário: " << endl;
   cin >> preço;
  
   cout << "O seu nome é: " << nome << endl;
   cout << "A sua idade é: " << quantidade << endl;
   cout << "O preço unitário é: " << preço << endl;
  
   return 0;
}

