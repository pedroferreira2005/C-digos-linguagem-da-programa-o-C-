#include <iostream>
using namespace std;
int main() {
 int A[3], B[3], D[3];
 for(int i = 0; i < 3; i++) {
 cin >> A[i];
 }
 for(int i = 0; i < 3; i++) {
 cin >> B[i];
 }
 for(int i = 0; i < 3; i++) {
 D[i] = A[i] - B[i];
 cout << D[i] << " ";
 }

 cout << endl;
 return 0;
}

