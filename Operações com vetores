#include <iostream>
using namespace std;
int main() {
 int A[3], B[3];
 int produtoEscalar = 0;
 for(int i = 0; i < 3; i++) {
 cin >> A[i];
 }
 for(int i = 0; i < 3; i++) {
 cin >> B[i];
 }
 for(int i = 0; i < 3; i++) {
 produtoEscalar += (A[i] * B[i]);
 }
 cout << produtoEscalar << endl;
 return 0;
}
