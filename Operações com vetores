#include <iostream>
using namespace std;
int main() {
 // Declarando e inicializando os 3 vetores com valores direto no código
 int v1[3] = {1, 2, 3};
 int v2[3] = {4, 5, 6};
 int v3[3] = {7, 8, 9};

 int soma[3];
 cout << "Vetor resultante da soma das posicoes:\n";

 // Somando os elementos das mesmas posições e exibindo
 for(int i = 0; i < 3; i++) {
 soma[i] = v1[i] + v2[i] + v3[i];
 cout << "Posicao " << i << ": " << soma[i] << "\n";
 }
 return 0;
}

