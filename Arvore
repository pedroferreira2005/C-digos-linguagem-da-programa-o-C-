#include <iostream>
// Definição da unidade fundamental da árvore
struct Node {
 int data;
 Node* left;
 Node* right;
 // Construtor: Garante a integridade dos ponteiros ao criar o nó
 Node(int val) : data(val), left(nullptr), right(nullptr) {}
};
// Função recursiva para alocação e encadeamento do nó
Node* insert(Node* root, int val) {
 // Caso Base: Posição disponível encontrada, aloca o nó no Heap
 if (root == nullptr) {
 return new Node(val);
 }
 // Passo Recursivo: Desce na hierarquia avaliando a precedência do valor
 if (val < root->data) {
 root->left = insert(root->left, val);
 } else if (val > root->data) {
 root->right = insert(root->right, val);
 }
 // Retorna o ponteiro do nó atual (inalterado) para reconstruir o encadeamento
 return root;
}

