#include <iostream>
#include <string>
using namespace std;
int main() {

 double a = 52.2;
 int b = 42;
 char c = 'V';
 string d = "aula";

 cout << "Tamanho de um double: " << sizeof(a) << endl;
 cout << "Tamanho de um int: " << sizeof(b) << endl;
 cout << "Tamanho de um char: " << sizeof(c) << endl;
 cout << "Tamanho de uma string: " << sizeof(d) << endl;
 return 0;
}

