#include <iostream>
using namespace std;
int main() {
 int *ponteiro;
 int valor = 10;
 ponteiro = &valor;

 cout << "Valor da variavel: " << valor << endl;
 cout << "Valor do ponteiro: " << *ponteiro << endl;
 cout << "Endereço na memória do ponteiro: " << ponteiro << endl;
 return 0;
}

--------------------------------------------------------------------------

#include <iostream>
using namespace std;
void incrementar(int *ponteiro) {
 *ponteiro = 10;
}
int main() {
 int variavel = 15;
 cout << "Valor antes da funcao: " << variavel << endl;
 incrementar(&variavel);
 cout << "Valor depois da funcao: " << variavel << endl;
 return 0;
}

