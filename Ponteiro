#include <iostream>
using namespace std;
void dobrar(int* ptr) {
 *ptr = (*ptr) * 2;
}
int main() {
 int valor = 5;

 cout << "valor = " << valor << endl;

 dobrar(&valor);

 cout << "Apos chamar a funcao:" << endl;
 cout << "valor = " << valor << endl;

 return 0;
}

