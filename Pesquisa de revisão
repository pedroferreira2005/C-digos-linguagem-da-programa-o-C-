#include <iostream>
using namespace std;
int main() {
 int num;
 do {
 cout << "Digite um numero positivo: ";
 cin >> num;
 } while (num <= 0); // Repete se for negativo ou zero
 cout << "Voce digitou: " << num << endl;
 return 0;
}
