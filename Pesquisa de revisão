#include <iostream>
using namespace std;
  int main() {
   int dia = 3;
   switch (dia) {
   case 1:
   cout << "Domingo" << endl;
   break;
   case 2:
   cout << "Segunda" << endl;
   break;
   case 3:
   cout << "Terca" << endl;
   break;
   default:
   cout << "Dia invalido" << endl;
   break;
   }
   return 0;
}

