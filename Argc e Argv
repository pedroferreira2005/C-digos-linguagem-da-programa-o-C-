#include <iostream>
using namespace std;
int main(int argc, char* argv[]) {
if (argc > 2) {
cout << "O argumento na posição 2 é: " << argv[2] << endl;
} else {
cout << "Você precisa passar pelo menos 2 argumentos!" << endl;
}
return 0;
}

